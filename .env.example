# Copy this file to .env and fill in values.

# --- Flask -----------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=production

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql://rapporter:rapporter@db:5432/rapporter
POSTGRES_DB=rapporter
POSTGRES_USER=rapporter
POSTGRES_PASSWORD=rapporter

# --- Redis (rate-limit counter store) --------------------------------------
# Points at the redis service in docker-compose. Falls back to in-memory if
# unset, which is fine for tests but loses counters across restarts.
REDIS_URL=redis://redis:6379/0

# --- Caddy / HTTPS ---------------------------------------------------------
# Three modes (see Caddyfile header for details):
#   Offline camp:    CADDY_DOMAIN=:80  and  CADDY_AUTO_HTTPS_LINE=auto_https off
#   Public ACME:     CADDY_DOMAIN=rapporter.example.se  (80/443 reachable)
#   Pre-issued cert: CADDY_DOMAIN=ticket.example.se  plus CADDY_TLS_LINE and
#                    CERTS_DIR (cert issued on another machine, copied here)
CADDY_DOMAIN=:80
CADDY_AUTO_HTTPS_LINE=auto_https off
# e.g. tls /certs/fullchain.pem /certs/privkey.pem
CADDY_TLS_LINE=
# Host directory holding the pre-issued cert files, mounted at /certs.
CERTS_DIR=./certs
# Contact email for Let's Encrypt (public ACME mode only).
CADDY_ACME_EMAIL=admin@example.com

# --- URL used by QR codes --------------------------------------------------
# Must be reachable by the devices that will scan the QR codes.
# Over HTTP on a LAN: http://<server-lan-ip>
# With a public domain: https://rapporter.example.se
BASE_URL=http://localhost

# --- Cookie security -------------------------------------------------------
# Set to 1 when running over plain HTTP so session cookies are not marked
# "Secure" (required for login to work over HTTP).
ALLOW_INSECURE_COOKIES=1
# Leave empty to let ALLOW_INSECURE_COOKIES decide.
SESSION_COOKIE_SECURE=
