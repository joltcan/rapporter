# Copy this file to .env and fill in values

# Flask secret key - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# PostgreSQL connection
DATABASE_URL=postgresql://rapporter:rapporter@db:5432/rapporter
POSTGRES_DB=rapporter
POSTGRES_USER=rapporter
POSTGRES_PASSWORD=rapporter

# Flask environment: production or development
FLASK_ENV=production

# Caddy domain - use localhost for local/offline use
# For production: set to your actual domain e.g. rapporter.example.com
CADDY_DOMAIN=localhost

# Base URL used for QR code generation
BASE_URL=https://localhost
