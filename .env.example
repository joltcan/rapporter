# Copy this file to .env and fill in values.

# --- Flask -----------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=production

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql://rapporter:rapporter@db:5432/rapporter
POSTGRES_DB=rapporter
POSTGRES_USER=rapporter
POSTGRES_PASSWORD=rapporter

# --- Caddy / HTTPS ---------------------------------------------------------
# Use "localhost" for offline camp deployments (plain HTTP, no ACME).
# Use a real hostname (e.g. rapporter.example.se) for automatic Let's Encrypt.
CADDY_DOMAIN=localhost
# Turn to "off" to stop Caddy from attempting ACME when running on a LAN
# without internet or DNS.
CADDY_AUTO_HTTPS=off
# Only used by ACME. Harmless placeholder when auto_https is off.
CADDY_ACME_EMAIL=admin@example.com

# --- URL used by QR codes --------------------------------------------------
# Must be reachable by the devices that will scan the QR codes.
# Over HTTP on a LAN: http://<server-lan-ip>
# With a public domain: https://rapporter.example.se
BASE_URL=http://localhost

# --- Cookie security -------------------------------------------------------
# Set to 1 when running over plain HTTP so session cookies are not marked
# "Secure" (required for login to work over HTTP).
ALLOW_INSECURE_COOKIES=1
# Leave empty to let ALLOW_INSECURE_COOKIES decide.
SESSION_COOKIE_SECURE=
